# =============================================================================
# DATABASE
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example: postgresql://postgres:mypassword@localhost:5432/my_portfolio
# Hosted example: get the connection string from Neon / Supabase dashboard
# =============================================================================
DATABASE_URL="postgresql://postgres@localhost:5432/my_portfolio"

# Direct (non-pooled) — used by Prisma for migrations
# Local: same as DATABASE_URL
# Production (Neon): use direct URL from Neon dashboard (hostname without -pooler)
DIRECT_URL="postgresql://postgres@localhost:5432/my_portfolio"

# =============================================================================
# SITE
# The public base URL of your portfolio (no trailing slash)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
# =============================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# =============================================================================
# CLOUDINARY (used for profile image and project image hosting)
# Sign up at https://cloudinary.com and find these in your dashboard
# =============================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
